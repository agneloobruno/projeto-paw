<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-" crossorigin="anonymous">
  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <header class="site-header">
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top streaming-nav">
      <div class="container-fluid px-4">
        <a class="navbar-brand fw-bold text-uppercase" href="/">PAW<span class="text-danger">+</span></a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav me-auto mb-2 mb-lg-0">
            <li class="nav-item"><a class="nav-link" href="/">Início</a></li>
            <li class="nav-item"><a class="nav-link" href="/categorias">Categorias</a></li>
            <li class="nav-item"><a class="nav-link" href="/filmes">Filmes</a></li>
          </ul>

          <form class="d-flex search-form me-3 position-relative" role="search" action="/filmes" method="get">
            <input id="searchInput" class="form-control form-control-sm search-input" name="q" type="search" placeholder="Pesquisar filmes" aria-label="Pesquisar" autocomplete="off" aria-autocomplete="list" aria-controls="searchSuggestions">
            <button class="btn btn-sm btn-outline-light ms-2" type="submit"><i class="bi bi-search"></i></button>
            <div id="searchSuggestions" role="listbox" aria-label="Sugestões de filmes" class="list-group position-absolute" style="z-index:1050; top:36px; left:0; right:40px; display:none; max-height:360px; overflow:auto;"></div>
          </form>

          <div class="nav-user d-flex align-items-center">
            <div class="dropdown">
              <a href="#" class="d-flex align-items-center text-decoration-none text-white" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                <img src="/images/avatar-placeholder.svg" alt="Avatar" class="avatar-img rounded-circle me-2">
                <span class="small text-muted">Usuário</span>
              </a>
              <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                <li><a class="dropdown-item" href="/profile">Perfil</a></li>
                <li><a class="dropdown-item" href="/settings">Configurações</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item text-danger" href="/logout">Sair</a></li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </nav>
  </header>

  <!-- Main container -->
  <div class="container mt-5 pt-4">

  <%- include('./_msg') %>

  <script>
    (function(){
      const input = document.getElementById('searchInput');
      const box = document.getElementById('searchSuggestions');
      if (!input || !box) return;
      let timeout = null;
      let activeIndex = -1;

      function clearSuggestions(){ box.style.display='none'; box.innerHTML=''; activeIndex = -1; }

      async function fetchSuggestions(v){
        try {
          const res = await fetch('/filmes/suggest?q=' + encodeURIComponent(v));
          if (!res.ok) throw new Error('err');
          const arr = await res.json();
          return arr || [];
        } catch(e){ return []; }
      }

      input.addEventListener('input', function(){
        const v = input.value.trim();
        if (timeout) clearTimeout(timeout);
        if (!v || v.length < 2) { clearSuggestions(); return; }
        timeout = setTimeout(async ()=>{
          const arr = await fetchSuggestions(v);
          if (!arr.length) { clearSuggestions(); return; }
          box.innerHTML = arr.map((a, idx)=> {
            const img = a.imagem ? `<img src="${a.imagem}" alt=""/>` : `<div style="width:40px;height:56px;display:inline-block;background:#222;border-radius:4px;margin-right:8px"></div>`;
            return `<a href="/filmes?q=${encodeURIComponent(a.titulo)}" role="option" data-index="${idx}" tabindex="0" class="list-group-item list-group-item-action d-flex align-items-center">${img}<span>${a.titulo}</span></a>`
          }).join('');
          box.style.display = 'block';
          activeIndex = -1;
        }, 200);
      });

      // keyboard navigation
      input.addEventListener('keydown', function(e){
        const items = Array.from(box.querySelectorAll('[role="option"]'));
        if (!items.length) return;
        if (e.key === 'ArrowDown'){
          e.preventDefault();
          activeIndex = Math.min(items.length - 1, activeIndex + 1);
          items[activeIndex].focus();
        } else if (e.key === 'ArrowUp'){
          e.preventDefault();
          activeIndex = Math.max(0, activeIndex - 1);
          items[activeIndex].focus();
        } else if (e.key === 'Escape'){
          clearSuggestions();
        }
      });

      // click/selection handlers
      box.addEventListener('click', function(e){
        const a = e.target.closest('a');
        if (a) { /* let anchor navigate */ }
      });

      // hide on outside click
      document.addEventListener('click', function(e){ if (!input.contains(e.target) && !box.contains(e.target)) { clearSuggestions(); } });
    })();
  </script>
