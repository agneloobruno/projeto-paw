<%- include('partials/header') %>

<!-- OMDb / seed area -->
<section class="mb-4">
	<% if (seedDone) { %>
		<div id="omdbArea">
			<div class="d-flex mb-3 align-items-center">
				<a href="/filmes/novo" class="btn btn-lg btn-primary">Adicionar filme</a>
				<div class="ms-3 text-muted">Catálogo populado.</div>
			</div>
		</div>
	<% } else { %>
		<div id="omdbArea">
			<div id="omdbCarousel" class="carousel slide mb-3" data-bs-ride="carousel">
			<div class="carousel-inner">
				<div class="carousel-item active">
					<div class="p-4 bg-dark text-white rounded">
						<h4>Chave OMDb necessária</h4>
						<p>Para que a aplicação busque pôsters e avaliações automaticamente, forneça uma chave de API gratuita obtida em <a href="https://www.omdbapi.com/" target="_blank" class="text-info">OMDb</a>.</p>
					</div>
				</div>
				<div class="carousel-item">
					<div class="p-4 bg-dark text-white rounded">
						<h4>Como obter</h4>
						<p>Cadastre-se no site e gere sua chave. Cole-a abaixo — não demora.</p>
					</div>
				</div>
				<div class="carousel-item">
					<div class="p-4 bg-dark text-white rounded">
						<h4>Popular com clássicos</h4>
						<p>Após fornecer a chave, um botão será liberado para popular o catálogo com 20 clássicos do cinema.</p>
					</div>
				</div>
			</div>
		</div>

		<div class="d-flex gap-2 align-items-center mb-4">
			<input id="omdbKeyInput" class="form-control form-control-sm" placeholder="Cole sua OMDb API key aqui" value="<%= typeof omdbKeyPresent !== 'undefined' && omdbKeyPresent ? '••••••••' : '' %>" />
			<button id="saveOmdbBtn" class="btn btn-primary btn-sm">Salvar chave</button>
			<button id="seedBtn" class="btn btn-success btn-sm" disabled>
				<span id="seedSpinner" class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"></span>
				<span id="seedLabel">Popular 20 clássicos</span>
			</button>
			<div id="omdbStatus" class="ms-3 small text-muted"></div>
		</div>
		<div id="seedDetails" class="small text-muted" style="white-space:pre-wrap;margin-top:.5rem;display:none"></div>

		<script>
			(function(){
				const keyInput = document.getElementById('omdbKeyInput');
				const saveBtn = document.getElementById('saveOmdbBtn');
				const seedBtn = document.getElementById('seedBtn');
				const status = document.getElementById('omdbStatus');
				const keyPresent = <%= (typeof omdbKeyPresent !== 'undefined' && omdbKeyPresent) ? 'true' : 'false' %>;
				if (keyPresent) seedBtn.disabled = false;

				saveBtn.addEventListener('click', async function(){
					const key = keyInput.value.trim();
					if (!key) { status.textContent = 'Chave vazia'; return; }
					status.textContent = 'Salvando...';
					try {
						const res = await fetch('/omdb-key', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ key }) });
						const j = await res.json();
						if (j.ok) {
							status.textContent = 'Chave salva.';
							seedBtn.disabled = false;
						} else {
							status.textContent = j.message || 'Erro ao salvar';
						}
					} catch (e) { status.textContent = 'Erro de rede'; }
				});

				seedBtn.addEventListener('click', async function(){
					if (!confirm('Executar script para popular 20 clássicos?')) return;
					seedBtn.disabled = true;
					document.getElementById('seedSpinner').classList.remove('d-none');
					document.getElementById('seedLabel').textContent = 'Executando...';
					status.textContent = 'Executando seed...';
					seedDetails.style.display = 'none';
					try {
						const res = await fetch('/seed-classics', { method: 'POST' });
						const j = await res.json();
						if (j.ok) {
							status.textContent = 'Seed concluído.';
							document.getElementById('seedSpinner').classList.add('d-none');
							document.getElementById('seedLabel').textContent = 'Concluído';
							// dynamically swap UI to 'seed done' state without reload
							try { showSeedDoneUI(); } catch(e) { setTimeout(()=> location.reload(), 1000); }
						} else {
							const msg = j.message || 'Erro no seed';
							status.textContent = msg;
							// show detailed stderr/stdout if present
							let details = '';
							if (j.stderr) details += 'STDERR:\n' + j.stderr + '\n';
							if (j.stdout) details += 'STDOUT:\n' + j.stdout + '\n';
							if (details) {
								seedDetails.textContent = details;
								seedDetails.style.display = 'block';
							}
							seedBtn.disabled = false;
							document.getElementById('seedSpinner').classList.add('d-none');
							document.getElementById('seedLabel').textContent = 'Popular 20 clássicos';
						}
					} catch (e) {
						status.textContent = 'Erro de rede';
						seedBtn.disabled = false;
						document.getElementById('seedSpinner').classList.add('d-none');
						document.getElementById('seedLabel').textContent = 'Popular 20 clássicos';
					}
				});

				function showSeedDoneUI(){
					const area = document.getElementById('omdbArea');
					if (!area) return;
					area.innerHTML = `<div class="d-flex mb-3 align-items-center">
						<a href="/filmes/novo" class="btn btn-lg btn-primary">Adicionar filme</a>
						<div class="ms-3 text-muted">Catálogo populado.</div>
					</div>`;
				}
			})();
		</script>
	<% } %>

<section class="hero-section mb-4">

<section class="hero-section mb-4">
	<% if (filmes && filmes.length && filmes[0]) { const f0 = filmes[0]; %>
		<div class="hero" style="background-image: url('<%= f0.imagem ? f0.imagem : '/images/poster-placeholder.svg' %>')">
			<div class="hero-overlay"></div>
			<div class="hero-content container">
				<div class="hero-meta-row">
					<h1 class="hero-title"><%= f0.titulo %></h1>
					<div class="hero-sub"> <%= f0.categoria || '' %> <% if (f0.ano) { %> • <%= f0.ano %><% } %> <% if (f0.imdb_rating) { %> • <i class="bi bi-star-fill"></i> <%= f0.imdb_rating %><% } %></div>
					<p class="hero-desc text-muted">Descubra trailers, avaliações e detalhes sobre este filme.</p>
					<div class="hero-actions">
						<a href="/filmes/editar/<%= f0.id %>" class="btn btn-primary btn-lg me-2" aria-label="Assistir <%= f0.titulo %>"><i class="bi bi-play-fill me-1"></i> Assistir</a>
						<a href="/filmes/editar/<%= f0.id %>" class="btn btn-outline-light btn-lg" aria-label="Adicionar <%= f0.titulo %> à minha lista"><i class="bi bi-plus-lg me-1"></i> Minha lista</a>
					</div>
				</div>
			</div>
		</div>
	<% } %>

	<div class="container mt-4">
		<h2 class="section-title mb-3">Novidades</h2>
		<div class="poster-grid">
			<% if (filmes && filmes.length) { filmes.forEach(function(f){ %>
				<div class="poster-card">
					<a href="/filmes/editar/<%= f.id %>" class="poster-link">
												<% if (f.imagem) { %>
													<img src="<%= f.imagem %>" alt="<%= f.titulo %>" class="poster-img" loading="lazy" width="300" height="450" />
												<% } else { %>
													<img src="/images/poster-placeholder.svg" alt="placeholder" class="poster-img img-placeholder" loading="lazy" width="300" height="450" />
												<% } %>
						<div class="poster-overlay">
							<div class="poster-title"><%= f.titulo %></div>
							<% if (f.imdb_rating) { %>
								<div class="poster-rating"><i class="bi bi-star-fill"></i> <%= f.imdb_rating %></div>
							<% } %>
						</div>
					</a>
				</div>
			<% }) } %>
		</div>
	</div>
</section>

<section class="mb-4">
	<div class="d-flex justify-content-between align-items-center mb-2">
		<h2 class="h5 mb-0">Categorias</h2>
		<a href="/categorias" class="btn btn-sm btn-outline-light">Ver todas</a>
	</div>
	<div class="categories-grid">
		<% if (categorias && categorias.length) { %>
			<% categorias.forEach(function(c){ %>
				<div class="category-tile" role="group" aria-label="Categoria <%= c.nome %>">
					<% if (c.image) { %>
					  <div class="category-bg" style="background-image:url('<%= c.image %>')"></div>
					<% } %>
					<div class="category-overlay"></div>
					<div class="category-center">
						<div class="category-icon">
							<i class="<%= c.icon || 'bi bi-film' %>" aria-hidden="true"></i>
						</div>
						<div class="category-name"><%= c.nome %></div>
						<div class="category-sub"><%= c.count %> filmes</div>
					</div>
					<div class="category-actions">
						<a href="/categorias/editar/<%= c.id %>" class="btn btn-sm btn-outline-warning me-2" title="Editar"><i class="bi bi-pencil"></i></a>
						<a href="#" data-href="/categorias/excluir/<%= c.id %>" data-name="<%= c.nome %>" class="btn btn-sm btn-danger btn-delete" title="Excluir"><i class="bi bi-trash"></i></a>
					</div>
				</div>
			<% }) %>
		<% } else { %>
			<div class="text-center">Nenhuma categoria cadastrada.</div>
		<% } %>
	</div>
</section>

<%- include('partials/footer') %>
