<%- include('partials/header') %>

<section class="mb-4">
	<div class="main-card p-4 d-flex align-items-center" style="gap:18px">
		<% if (filmes && filmes.length) { %>
			<div style="flex:1;min-width:320px">
				<h2 class="h4 mb-2">Em destaque</h2>
				<div class="d-flex gap-3">
					<% filmes.slice(0,1).forEach(function(f){ %>
						<div style="max-width:420px">
							<% if (f.imagem) { %>
								<img src="<%= f.imagem %>" alt="<%= f.titulo %>" style="width:100%;height:260px;object-fit:cover;border-radius:8px;" />
							<% } else { %>
								<img src="/images/poster-placeholder.svg" alt="placeholder" style="width:100%;height:260px;object-fit:cover;border-radius:8px;" />
							<% } %>
						</div>
					<% }) %>
					<div style="flex:1">
						<h3 class="movie-title mb-1"><%= filmes[0] ? filmes[0].titulo : '' %></h3>
						<div class="text-muted mb-2"><%= filmes[0] ? (filmes[0].categoria || '') + (filmes[0].ano ? ' • ' + filmes[0].ano : '') : '' %></div>
						<p class="text-muted small">Descubra trailers, avaliações e mais.</p>
					</div>
				</div>
			</div>
			<div style="flex:1">
				<h2 class="h5 mb-2">Novidades</h2>
				<div class="movies-grid">
					<% filmes.forEach(function(f,i){ %>
						<div class="movie-card <%='cat-'+(i%6)%>" >
							<div class="movie-poster">
								<% if (f.imagem) { %>
									<img src="<%= f.imagem %>" alt="<%= f.titulo %>" />
								<% } else { %>
									<img src="/images/poster-placeholder.svg" alt="placeholder" />
								<% } %>
							</div>
							<div class="movie-meta">
								<div class="movie-title"><%= f.titulo %></div>
								<div class="movie-cat"><%= f.categoria || '' %> <% if (f.ano) { %>• <%= f.ano %><% } %></div>
							</div>
							<% if (f.imdb_rating) { %>
								<div class="movie-badge"><i class="bi bi-star-fill"></i> <%= f.imdb_rating %></div>
							<% } %>
						</div>
					<% }) %>
				</div>
			</div>
		<% } else { %>
			<div class="text-center p-4">Nenhum filme encontrado.</div>
		<% } %>
	</div>
</section>

<section class="mb-4">
	<div class="d-flex justify-content-between align-items-center mb-2">
		<h2 class="h5 mb-0">Categorias</h2>
		<a href="/categorias" class="btn btn-sm btn-outline-light">Ver todas</a>
	</div>
	<div class="categories-row">
		<% if (categorias && categorias.length) { %>
			<% categorias.forEach(function(c){ %>
				<div class="category-tile">
					<div>
						<div class="category-name"><%= c.nome %></div>
						<div class="text-muted small"><%= c.count %> filmes</div>
					</div>
					<div class="category-actions d-flex justify-content-end">
						<a href="/categorias/editar/<%= c.id %>" class="btn btn-sm btn-outline-warning me-2" title="Editar"><i class="bi bi-pencil"></i></a>
						<a href="#" data-href="/categorias/excluir/<%= c.id %>" data-name="<%= c.nome %>" class="btn btn-sm btn-danger btn-delete" title="Excluir"><i class="bi bi-trash"></i></a>
					</div>
				</div>
			<% }) %>
		<% } else { %>
			<div class="text-center">Nenhuma categoria cadastrada.</div>
		<% } %>
	</div>
</section>

<%- include('partials/footer') %>
