<%- include('../partials/header') %>

<h1>Editar Filme</h1>

<form action="/filmes/atualizar" method="post" class="mt-3">
  <input type="hidden" name="id" value="<%= filme.id %>" />

  <div class="mb-3">
    <label for="titulo" class="form-label">Título</label>
    <input id="titulo" class="form-control" type="text" name="titulo" value="<%= filme.titulo %>" required />
  </div>

  <div class="mb-3">
    <label for="ano" class="form-label">Ano</label>
    <input id="ano" class="form-control" type="number" name="ano" value="<%= filme.ano || '' %>" />
  </div>

  <div class="mb-3">
    <label for="categoria" class="form-label">Categoria</label>
    <select id="categoria" name="categoria_id" class="form-select" required>
      <option value="">-- selecione --</option>
      <% categorias.forEach(function(c){ %>
        <option value="<%= c.id %>" <%= c.id == filme.categoria_id ? 'selected' : '' %>><%= c.nome %></option>
      <% }) %>
    </select>
  </div>

  <div class="mb-3">
    <label class="form-label">Imagem atual</label>
    <div>
      <% if (filme.imagem) { %>
        <img src="<%= filme.imagem %>" alt="Poster" style="height:140px;object-fit:cover;border-radius:6px;" />
      <% } else { %>
        <img src="/images/poster-placeholder.svg" alt="Placeholder" style="height:140px;object-fit:cover;border-radius:6px;" />
      <% } %>
    </div>
  </div>
  <div class="mb-3">
    <label class="form-label">Alterar imagem (upload)</label>
    <input type="file" name="imagem_file" accept="image/*" class="form-control" />
    <div class="form-text">Ou atualize a URL abaixo.</div>
  </div>
  <div class="mb-3">
    <label class="form-label">URL da Imagem</label>
    <input type="url" name="imagem_url" class="form-control" value="<%= filme.imagem || '' %>" />
  </div>

  <div class="d-flex gap-2">
    <button type="submit" class="btn btn-primary">Atualizar</button>
    <a href="/filmes" class="btn btn-secondary">Voltar</a>
  </div>
</form>

<%- include('../partials/footer') %>
