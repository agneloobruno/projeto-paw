<%- include('../partials/header') %>

<h1>Novo Filme</h1>

<form action="/filmes/salvar" method="post" class="mt-3">
  <div class="mb-3">
    <label for="titulo" class="form-label">Título</label>
    <input id="titulo" class="form-control" type="text" name="titulo" required />
  </div>

  <div class="mb-3">
    <label for="ano" class="form-label">Ano</label>
    <input id="ano" class="form-control" type="number" name="ano" />
  </div>

  <div class="mb-3">
    <label for="categoria" class="form-label">Categoria</label>
    <select id="categoria" name="categoria_id" class="form-select" required>
      <option value="">-- selecione --</option>
      <% categorias.forEach(function(c){ %>
        <option value="<%= c.id %>"><%= c.nome %></option>
      <% }) %>
    </select>
  </div>

  <div class="d-flex gap-2">
    <button type="submit" class="btn btn-primary">Salvar</button>
    <a href="/filmes" class="btn btn-secondary">Voltar</a>
  </div>
</form>

<%- include('../partials/footer') %>
