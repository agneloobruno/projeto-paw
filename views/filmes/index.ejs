<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h3 mb-0">Filmes</h1>
  <a href="/filmes/novo" class="btn btn-sm btn-success">Novo filme</a>
</div>

<div class="main-card">
  <% if (filmes && filmes.length) { %>
    <div class="movies-grid">
      <% filmes.forEach(function(f){ %>
        <div class="movie-card cat-<%= f.categoria_id || 0 %>" data-category="<%= f.categoria || '' %>">
          <div class="movie-badge"><% if (f.ano) { %><%= f.ano %><% } else { %>—<% } %></div>
          <div class="movie-poster">
            <% if (f.imagem) { %>
              <img src="<%= f.imagem %>" alt="<%= f.titulo %>" style="width:100%;height:100%;object-fit:cover;display:block" />
            <% } else { %>
              <img src="/images/poster-placeholder.svg" alt="Poster" style="width:100%;height:100%;object-fit:cover;display:block" />
            <% } %>
          </div>
          <div class="movie-meta">
            <div class="movie-title"><%= f.titulo %></div>
            <div class="d-flex justify-content-between align-items-center">
              <div class="movie-cat"><%= f.categoria || '—' %></div>
              <div>
                <a href="/filmes/editar/<%= f.id %>" class="btn btn-sm btn-outline-warning me-1" title="Editar">
                  <i class="bi bi-pencil"></i>
                </a>
                <a href="#" data-href="/filmes/excluir/<%= f.id %>" data-name="<%= f.titulo %>" class="btn btn-sm btn-danger btn-delete" title="Excluir">
                  <i class="bi bi-trash"></i>
                </a>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <div class="text-center py-4">
      <p class="mb-2">Nenhum filme cadastrado.</p>
      <a href="/filmes/novo" class="btn btn-sm btn-primary">Cadastrar Novo</a>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
