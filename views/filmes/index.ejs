<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h3 mb-0">Filmes</h1>
  <a href="/filmes/novo" class="btn btn-sm btn-success">Novo filme</a>
</div>

<div class="main-card">
  <% if (filmes && filmes.length) { %>
    <table class="table table-hover table-striped">
      <thead>
        <tr>
          <th>Título</th>
          <th>Ano</th>
          <th>Categoria</th>
          <th style="width:140px;text-align:right">Ações</th>
        </tr>
      </thead>
      <tbody>
        <% filmes.forEach(function(f){ %>
          <tr>
            <td><%= f.titulo %></td>
            <td>
              <% if (f.ano) { %>
                <span class="badge bg-info text-dark"><%= f.ano %></span>
              <% } %>
            </td>
            <td><%= f.categoria || '—' %></td>
            <td class="text-end">
              <a href="/filmes/editar/<%= f.id %>" class="btn btn-sm btn-warning me-1" title="Editar">
                <i class="bi bi-pencil"></i>
              </a>
              <a href="#" data-href="/filmes/excluir/<%= f.id %>" data-name="<%= f.titulo %>" class="btn btn-sm btn-danger btn-delete" title="Excluir">
                <i class="bi bi-trash"></i>
              </a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } else { %>
    <div class="text-center py-4">
      <p class="mb-2">Nenhum filme cadastrado.</p>
      <a href="/filmes/novo" class="btn btn-sm btn-primary">Cadastrar Novo</a>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
